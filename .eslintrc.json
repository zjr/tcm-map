{
	"extends": [
		"eslint:recommended",

		"plugin:@typescript-eslint/recommended",
		"prettier"
	],
	"parser": "@typescript-eslint/parser",
	"plugins": ["@typescript-eslint"],
	"env": { "es6": true, "node": true, "browser": true },
	"parserOptions": {
		"sourceType": "module"
	},
	"rules": {
		"linebreak-style": ["error", "unix"]
	}
}
