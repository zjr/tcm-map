{
	"name": "tcm-map",
	"private": true,
	"version": "0.0.0",
	"scripts": {
		"dev": "nodemon --signal SIGINT src/server/main.ts -w src/server",
		"start": "NODE_ENV=production ts-node src/server/main.ts",
		"build": "./node_modules/.bin/vite build",
		"prepare": "[ -d '.husky' ] && husky install || true",
		"commit": "commit",
		"release": "standard-version",
		"h:pre-commit": "lint-staged",
		"db:migrate": "npm run db:migrate:generate && npm run db:migrate:run",
		"db:migrate:docker": "docker compose -f compose.migrate.yaml up --build --abort-on-container-exit",
		"db:migrate:generate": "drizzle-kit generate:pg",
		"db:migrate:run": "tsx src/server/db/migrate.ts"
	},
	"lint-staged": {
		"*": "prettier --ignore-unknown --write",
		"*.js": "eslint"
	},
	"devDependencies": {
		"@tailwindcss/forms": "^0.5.6",
		"@types/cors": "^2.8.15",
		"@types/express": "^4.17.15",
		"@types/google.maps": "^3.54.6",
		"@types/lodash": "^4.14.201",
		"@types/lodash-es": "^4.17.11",
		"@types/node": "^18.11.18",
		"@typescript-eslint/eslint-plugin": "^6.9.1",
		"@typescript-eslint/parser": "^6.9.1",
		"autoprefixer": "^10.4.16",
		"commitlint": "^18.2.0",
		"drizzle-kit": "^0.20.4",
		"eslint": "^8.52.0",
		"eslint-config-prettier": "^9.0.0",
		"husky": "^8.0.0",
		"lint-staged": "^15.0.2",
		"nodemon": "^2.0.20",
		"postcss-nested": "^6.0.1",
		"prettier": "^3.0.3",
		"prettier-plugin-ejs": "^0.0.18",
		"prettier-plugin-tailwindcss": "^0.5.6",
		"standard-version": "^9.5.0",
		"tailwindcss": "^3.3.5",
		"tsx": "^4.3.0",
		"vite": "^4.0.4"
	},
	"dependencies": {
		"@dotenvx/dotenvx": "^1.57.1",
		"@googlemaps/js-api-loader": "^1.16.2",
		"@googlemaps/markerclusterer": "^2.5.1",
		"@lit/context": "^1.0.1",
		"cors": "^2.8.5",
		"drizzle-orm": "^0.29.0",
		"ejs": "^3.1.9",
		"express": "^4.18.2",
		"graphql": "^16.8.1",
		"graphql-request": "^6.1.0",
		"lit": "^3.0.1",
		"lodash-es": "^4.17.21",
		"postgres": "^3.4.3",
		"ts-node": "^10.9.1",
		"typescript": "^4.9.3",
		"vite-express": "*"
	}
}
